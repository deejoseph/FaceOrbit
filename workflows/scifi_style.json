{
  "1": {
    "inputs": {"ckpt_name": "ghostxl_v10BakedVAE.safetensors"},
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "GhostXL 2.5D模型"}
  },
  "3": {
    "inputs": {"image": "身份.jpg"},
    "class_type": "LoadImage",
    "_meta": {"title": "身份参考图"}
  },
  "4": {
    "inputs": {"instantid_file": "ip-adapter.bin"},
    "class_type": "InstantIDModelLoader",
    "_meta": {"title": "InstantID模型"}
  },
  "5": {
    "inputs": {"provider": "CUDA"},
    "class_type": "InstantIDFaceAnalysis",
    "_meta": {"title": "人脸分析"}
  },
  "6": {
    "inputs": {"control_net_name": "control_instant_id_sdxl.safetensors"},
    "class_type": "ControlNetLoader",
    "_meta": {"title": "InstantID ControlNet"}
  },
  "7": {
    "inputs": {
      "text": "masterpiece, best quality, very aesthetic, 1girl, cyberpunk, neon light, sci-fi, detailed face, vibrant colors, high contrast, sharp focus, 8k, ultra detailed, beautiful lighting",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "正向提示词"}
  },
  "8": {
    "inputs": {
      "text": "nsfw, lowres, bad anatomy, bad hands, worst quality, low quality, blurry, ugly, deformed, grayscale, dull, washed out, low contrast, noisy, pixelated, jpeg artifacts, watermark, text, signature, extra fingers, fused fingers, bad proportions, disfigured",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "负向提示词"}
  },
  "9": {
    "inputs": {
      "weight": 0.88,
      "cn_strength": 0.5,
      "start_at": 0,
      "end_at": 0.78,
      "instantid": ["4", 0],
      "insightface": ["5", 0],
      "control_net": ["6", 0],
      "image": ["3", 0],
      "model": ["1", 0],
      "positive": ["7", 0],
      "negative": ["8", 0]
    },
    "class_type": "ApplyInstantID",
    "_meta": {"title": "InstantID"}
  },
  "10": {
    "inputs": {"width": 1024, "height": 1024, "batch_size": 1},
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "潜空间"}
  },
  "11": {
    "inputs": {
      "seed": 42,
      "steps": 35,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.65,
      "model": ["9", 0],
      "positive": ["9", 1],
      "negative": ["9", 2],
      "latent_image": ["10", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "采样器"}
  },
  "12": {
    "inputs": {"vae_name": "sdxl_vae.safetensors"},
    "class_type": "VAELoader",
    "_meta": {"title": "VAE加载器"}
  },
  "13": {
    "inputs": {"samples": ["11", 0], "vae": ["12", 0]},
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE解码"}
  },
  "14": {
    "inputs": {
      "correction_strength": 0.45,
      "method": "luminance_zones",
      "auto_preserve": true,
      "lock_input_image": false,
      "original_image": ["3", 0],
      "processed_image": ["13", 0]
    },
    "class_type": "VAEColorCorrector",
    "_meta": {"title": "VAE色彩校正"}
  },
  "15": {
    "inputs": {"filename_prefix": "scifi_style", "images": ["14", 0]},
    "class_type": "SaveImage",
    "_meta": {"title": "保存图片"}
  }
}