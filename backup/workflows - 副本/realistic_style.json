{
  "1": {
    "inputs": {"ckpt_name": "realvisxlV50_v50LightningBakedvae.safetensors"},
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "模型加载-RealVisXL"}
  },
  "2": {
    "inputs": {
      "lora_name": "qwen-image-edit-2511-multiple-angles-lora.safetensors",
      "strength_model": 0.5,
      "model": ["1", 0]
    },
    "class_type": "LoraLoaderModelOnly",
    "_meta": {"title": "多角度 LoRA"}
  },
  "3": {
    "inputs": {"image": "身份.jpg"},
    "class_type": "LoadImage",
    "_meta": {"title": "身份参考图"}
  },
  "4": {
    "inputs": {"instantid_file": "ip-adapter.bin"},
    "class_type": "InstantIDModelLoader",
    "_meta": {"title": "InstantID模型"}
  },
  "5": {
    "inputs": {"provider": "CUDA"},
    "class_type": "InstantIDFaceAnalysis",
    "_meta": {"title": "人脸分析"}
  },
  "6": {
    "inputs": {"control_net_name": "control_instant_id_sdxl.safetensors"},
    "class_type": "ControlNetLoader",
    "_meta": {"title": "InstantID ControlNet"}
  },
  "7": {
    "inputs": {
      "text": "centered, portrait photo of 35 y.o woman, open jacket, sweater, natural skin, dark shot",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "正向提示词"}
  },
  "8": {
    "inputs": {
      "text": "nsfw, lowres, bad anatomy, bad hands, text, error, missing fingers, extra digit, fewer digits, cropped, worst quality, low quality, normal quality, jpeg artifacts, signature, watermark, username, blurry, artist name, ugly, deformed",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "负向提示词"}
  },
  "9": {
    "inputs": {
      "weight": 0.9,
      "cn_strength": 0.5,
      "start_at": 0,
      "end_at": 0.8,
      "instantid": ["4", 0],
      "insightface": ["5", 0],
      "control_net": ["6", 0],
      "image": ["3", 0],
      "model": ["2", 0],
      "positive": ["7", 0],
      "negative": ["8", 0]
    },
    "class_type": "ApplyInstantID",
    "_meta": {"title": "InstantID"}
  },
  "10": {
    "inputs": {"width": 896, "height": 1152, "batch_size": 1},
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "潜空间"}
  },
  "11": {
    "inputs": {
      "seed": 42,
      "steps": 25,
      "cfg": 2.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.7,
      "model": ["9", 0],
      "positive": ["9", 1],
      "negative": ["9", 2],
      "latent_image": ["10", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "采样器"}
  },
  "12": {
    "inputs": {"vae_name": "sdxl_vae.safetensors"},
    "class_type": "VAELoader",
    "_meta": {"title": "VAE加载器"}
  },
  "13": {
    "inputs": {"samples": ["11", 0], "vae": ["12", 0]},
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE解码"}
  },
  "14": {
    "inputs": {
      "correction_strength": 0.4,
      "method": "luminance_zones",
      "auto_preserve": true,
      "lock_input_image": false,
      "original_image": ["3", 0],
      "processed_image": ["13", 0]
    },
    "class_type": "VAEColorCorrector",
    "_meta": {"title": "VAE色彩校正"}
  },
  "15": {
    "inputs": {"filename_prefix": "realistic_style", "images": ["14", 0]},
    "class_type": "SaveImage",
    "_meta": {"title": "保存图片"}
  }
}