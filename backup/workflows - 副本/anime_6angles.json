{
  "1": {
    "inputs": {"ckpt_name": "animagine-xl-3.1.safetensors"},
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "主模型"}
  },
  "2": {
    "inputs": {
      "lora_name": "qwen-image-edit-2511-multiple-angles-lora.safetensors",
      "strength_model": 0.3,
      "model": ["1", 0]
    },
    "class_type": "LoraLoaderModelOnly",
    "_meta": {"title": "多角度 LoRA"}
  },
  "3": {
    "inputs": {"image": "your_face.jpg"},
    "class_type": "LoadImage",
    "_meta": {"title": "身份参考图"}
  },
  "4": {
    "inputs": {"instantid_file": "ip-adapter.bin"},
    "class_type": "InstantIDModelLoader",
    "_meta": {"title": "InstantID模型"}
  },
  "5": {
    "inputs": {"provider": "CUDA"},
    "class_type": "InstantIDFaceAnalysis",
    "_meta": {"title": "人脸分析"}
  },
  "6": {
    "inputs": {"control_net_name": "diffusion_pytorch_model.safetensors"},
    "class_type": "ControlNetLoader",
    "_meta": {"title": "ControlNet"}
  },
  "8": {
    "inputs": {
      "text": "nsfw, lowres, bad anatomy, bad hands, text, error, missing fingers, extra digit, fewer digits, cropped, worst quality, low quality, normal quality, jpeg artifacts, signature, watermark, username, blurry, artist name, ugly, deformed, grayscale, dull, washed out, desaturated, low contrast",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "负向提示词"}
  },
  "10": {
    "inputs": {"width": 832, "height": 1216, "batch_size": 6},
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "潜空间(6批次)"}
  },
  "12": {
    "inputs": {"vae_name": "sdxl_vae.safetensors"},
    "class_type": "VAELoader",
    "_meta": {"title": "VAE加载器"}
  },
  "7_front": {
    "inputs": {
      "text": "masterpiece, best quality, very aesthetic, 1man, front view, looking at viewer, solo, upper body, plain background, vibrant, high saturation, colorful, bright, detailed face",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "提示词-正面"}
  },
  "9_front": {
    "inputs": {
      "ip_weight": 0.8, "cn_strength": 0.35, "start_at": 0, "end_at": 0.75, "noise": 0, "combine_embeds": "average",
      "instantid": ["4", 0], "insightface": ["5", 0], "control_net": ["6", 0],
      "image": ["3", 0], "model": ["2", 0],
      "positive": ["7_front", 0], "negative": ["8", 0]
    },
    "class_type": "ApplyInstantIDAdvanced",
    "_meta": {"title": "InstantID-正面"}
  },
  "11_front": {
    "inputs": {
      "seed": 42, "steps": 28, "cfg": 6.5, "sampler_name": "euler_ancestral", "scheduler": "simple", "denoise": 0.7,
      "model": ["9_front", 0], "positive": ["9_front", 1], "negative": ["9_front", 2], "latent_image": ["10", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "采样器-正面"}
  },
  "13_front": {
    "inputs": {"samples": ["11_front", 0], "vae": ["12", 0]},
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE解码-正面"}
  },
  "14_front": {
    "inputs": {
      "correction_strength": 0.65, "method": "luminance_zones", "auto_preserve": true, "lock_input_image": false,
      "original_image": ["3", 0], "processed_image": ["13_front", 0]
    },
    "class_type": "VAEColorCorrector",
    "_meta": {"title": "色彩校正-正面"}
  },
  "15_front": {
    "inputs": {"filename_prefix": "anime_front", "images": ["14_front", 0]},
    "class_type": "SaveImage",
    "_meta": {"title": "保存-正面"}
  },
